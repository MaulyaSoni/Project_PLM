generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ENGINEERING
  APPROVER
  OPERATIONS
}

enum ECOType {
  PRODUCT
  BOM
}

enum Status {
  ACTIVE
  ARCHIVED
}

enum ECOStageStatus {
  NEW
  IN_REVIEW
  APPROVED
  DONE
}

enum AuditActionType {
  CREATE
  UPDATE
  APPROVE
  REJECT
  ARCHIVE
}

model User {
  id          String        @id @default(uuid())
  name        String
  email       String        @unique
  password    String
  role        Role          @default(ENGINEERING)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  ecos        ECO[]         @relation("CreatedECOs")
  assignedEco ECO[]         @relation("AssignedECOs")
  approvals   ECOApproval[]
  auditLogs   AuditLog[]
  aiResults   AiResult[]
  notifications Notification[]
}

model Product {
  id             String           @id @default(uuid())
  name           String
  currentVersion Int              @default(1)
  status         Status           @default(ACTIVE)
  createdAt      DateTime         @default(now())

  versions       ProductVersion[]
  ecos           ECO[]
  boms           BOM[]
}

model ProductVersion {
  id         String   @id @default(uuid())
  productId  String
  version    Int
  salePrice  Float
  costPrice  Float
  status     Status   @default(ACTIVE)
  createdAt  DateTime @default(now())
  createdVia String?

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, version])
}

model BOM {
  id         String         @id @default(uuid())
  productId  String
  version    Int            @default(1)
  status     Status         @default(ACTIVE)
  createdAt  DateTime       @default(now())

  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  components BOMComponent[]
  operations BOMOperation[]
  ecos       ECO[]
}

model BOMComponent {
  id             String  @id @default(uuid())
  bomId          String
  componentName  String
  quantity       Float
  unit           String

  bom            BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
}

model BOMOperation {
  id          String  @id @default(uuid())
  bomId       String
  name        String
  duration    Int
  workCenter  String

  bom         BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
}

model ECOStage {
  id               String  @id @default(uuid())
  name             String  @unique
  order            Int     @unique
  requiresApproval Boolean @default(false)

  ecos             ECO[]
}

model ECO {
  id                 String          @id @default(uuid())
  title              String
  type               ECOType
  productId          String
  bomId              String?
  userId             String
  assignedToId       String?
  effectiveDate      DateTime?
  versionUpdate      Boolean         @default(true)
  stageId            String
  status             ECOStageStatus  @default(NEW)
  productChanges     Json?
  bomComponentChanges Json?
  description         String?         @db.Text
  aiAnalysis          String?         @map("ai_analysis") // cached JSON from impact analysis
  aiSummary           String?         @map("ai_summary")  // cached one-line summary
  aiTags              String?         @map("ai_tags")     // cached JSON array of tags
  aiQualityScore      String?         @map("ai_quality_score")
  aiComplexityData    String?         @map("ai_complexity_data")
  aiTemplateSuggestion String?        @map("ai_template_suggestion")
  aiPrecedents        String?         @map("ai_precedents")
  aiApprovalPrediction String?        @map("ai_approval_prediction")
  aiBomImpactGraph     String?        @map("ai_bom_impact_graph")
  createdAt           DateTime        @default(now())

  product            Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  bom                BOM?            @relation(fields: [bomId], references: [id], onDelete: SetNull)
  user               User            @relation("CreatedECOs", fields: [userId], references: [id], onDelete: Restrict)
  assignedTo         User?           @relation("AssignedECOs", fields: [assignedToId], references: [id], onDelete: SetNull)
  stage              ECOStage        @relation(fields: [stageId], references: [id], onDelete: Restrict)
  approvals          ECOApproval[]
  auditLogs          AuditLog[]
  aiResults          AiResult[]
  agentActions       AgentAction[]
  learningRecords    TemplateLearningRecord[]
  notifications      Notification[]
}

model AgentAction {
  id           String   @id @default(uuid())
  ecoId        String?  @map("eco_id")
  targetUserId String?  @map("target_user_id")
  actionType   String   @map("action_type")
  reasoning    String?
  context      String?
  outcome      String?
  status       String   @default("EXECUTED")
  reason       String?
  message      String
  metadata     Json?
  source       String   @default("scheduler")
  scheduledFor DateTime? @map("scheduled_for")
  executedAt   DateTime? @map("executed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  eco          ECO?     @relation(fields: [ecoId], references: [id], onDelete: Cascade)

  @@index([ecoId, actionType, createdAt])
  @@map("agent_actions")
}

model AiResult {
  id          String   @id @default(uuid())
  ecoId       String?  @map("eco_id")
  userId      String?  @map("user_id")
  featureType String   @map("feature_type")
  input       String
  output      String
  modelUsed   String   @default("llama-3.1-70b-versatile") @map("model_used")
  latencyMs   Int?     @map("latency_ms")
  cached      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  eco         ECO?     @relation(fields: [ecoId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@map("ai_results")
}

model ECOApproval {
  id                 String   @id @default(uuid())
  ecoId              String
  userId             String
  approved           Boolean
  comment            String?
  checklistCompleted Boolean  @default(false) @map("checklist_completed")
  checklistItems     String?  @map("checklist_items") // JSON array of completed checklist keys
  createdAt          DateTime @default(now())

  eco        ECO      @relation(fields: [ecoId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([ecoId, userId])
}

model AuditLog {
  id         String          @id @default(uuid())
  ecoId      String?
  userId     String
  action     String
  actionType AuditActionType
  oldValue   String?
  newValue   String?
  createdAt  DateTime        @default(now())

  eco        ECO?            @relation(fields: [ecoId], references: [id], onDelete: SetNull)
  user       User            @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model TemplateLearningRecord {
  id                  String   @id @default(uuid())
  ecoId               String   @unique @map("eco_id")
  productId           String   @map("product_id")
  ecoType             ECOType  @map("eco_type")
  title               String
  description         String?  @db.Text
  normalizedPattern   String   @map("normalized_pattern") @db.Text
  outcomeQualityScore Float?   @map("outcome_quality_score")
  cycleTimeDays       Float?   @map("cycle_time_days")
  approvedFirstPass   Boolean  @default(false) @map("approved_first_pass")
  createdAt           DateTime @default(now()) @map("created_at")

  eco                 ECO      @relation(fields: [ecoId], references: [id], onDelete: Cascade)

  @@index([productId, ecoType, createdAt])
  @@map("template_learning_records")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  ecoId      String?  @map("eco_id")
  channel    String
  title      String
  message    String   @db.Text
  metadata   Json?
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eco        ECO?     @relation(fields: [ecoId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("notifications")
}
